# =============================================================================
# Backend API — variables de entorno
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:5173
LOG_LEVEL=info

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Prisma) -----------------------------------------------------
# Usa el connection pooler de Supabase para DATABASE_URL
# y la conexión directa para DIRECT_URL (requerida por Prisma migrate).
DATABASE_URL=
DIRECT_URL=

# --- Proveedores de IA -----------------------------------------------------
# Al menos OPENAI_API_KEY *o* OPENROUTER_API_KEY es obligatorio.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Opcional — habilita análisis visual, generación de imágenes y detección
# de competidores vía Gemini 2.5 Flash con Google Search grounding.
GEMINI_API_KEY=

# Opcional — Firecrawl se usa para scraping de sitios web. Si no se provee,
# el websiteAnalyzer devuelve análisis vacío.
FIRECRAWL_API_KEY=

# Opcional — Tavily se usa para búsqueda web (noticias, trending, competitor analyzer).
TAVILY_API_KEY=

# Opcional — Apify se usa para scraping de Instagram/TikTok.
APIFY_API_KEY=

# --- Google Cloud (opcional, para Vertex AI / imágenes avanzadas) ----------
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=
GOOGLE_CLIENT_EMAIL=
GOOGLE_ACCESS_TOKEN=
