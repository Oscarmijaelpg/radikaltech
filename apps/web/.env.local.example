# =============================================================================
# apps/web — Variables de entorno del frontend (Vite)
#
# Copia este archivo a .env.local y rellena los valores.
# NUNCA comitees .env.local — está excluido en .gitignore.
# =============================================================================

# --- Supabase (obligatorio) --------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- API backend (obligatorio) -----------------------------------------------
# URL base del API de Hono. En desarrollo apunta al puerto local de apps/api.
VITE_API_URL=http://localhost:3001/api/v1

# --- Observabilidad (opcional) -----------------------------------------------
# DSN de Sentry para reporte de errores en producción
# VITE_SENTRY_DSN=
