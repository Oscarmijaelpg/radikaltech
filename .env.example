# =============================================================================
# RADIKAL — Variables de entorno (referencia)
#
# Este archivo es SÓLO referencia. Cada app tiene su propio .env:
#   - apps/web/.env.local  → variables del frontend (VITE_*)
#   - apps/api/.env        → variables del backend
#
# NO comitees archivos .env reales. El .gitignore los excluye.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Database (Prisma sobre Postgres de Supabase) --------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# --- API / Web endpoints ---------------------------------------------------
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# --- Proveedores de IA -----------------------------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
APIFY_API_KEY=
