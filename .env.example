# =============================================================================
# RADIKAL — Variables de entorno (referencia)
#
# Este archivo es SÓLO referencia. Cada app tiene su propio .env:
#   - apps/web/.env.local  → variables del frontend (VITE_*)
#   - apps/api/.env        → variables del backend
#
# NO comitees archivos .env reales. El .gitignore los excluye.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Database (Prisma sobre Postgres de Supabase) --------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# --- API / Web endpoints ---------------------------------------------------
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# --- Proveedores de IA -----------------------------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
APIFY_API_KEY=

# --- Observabilidad y logging -----------------------------------------------
# Nivel de log pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# NODE_ENV controla el formato de logs (pretty en dev, JSON en prod)
NODE_ENV=development

# --- Timeouts (ms) -----------------------------------------------------------
# Tiempo máximo de espera para scrapes externos (default: 60000)
SCRAPE_TIMEOUT=60000

# --- Moonshot (proveedor LLM opcional) ------------------------------------
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Google (proveedor LLM opcional) -------------------------------------
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
